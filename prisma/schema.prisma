// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderType {
  RENT
  PURCHASE
  MIXED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DISPATCHED
  DELIVERED
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CartItemType {
  RENTAL
  PURCHASE
}

enum ReturnStatus {
  PENDING
  RETURNED
  DAMAGED
}

enum DepositStatus {
  HELD
  REFUNDED
  FORFEITED
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  phone        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cart    Cart?
  orders  Order[]
  reviews Review[]
}

// ─────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

// ─────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────

model Product {
  id                 String   @id @default(cuid())
  title              String
  description        String
  categoryId         String
  rentalPricePerDay  Float?
  purchasePrice      Float?
  deposit            Float?   @default(0)
  stock              Int      @default(0)
  rentalEnabled      Boolean  @default(false)
  purchaseEnabled    Boolean  @default(true)
  averageRating      Float?   @default(0)
  totalReviews       Int      @default(0)
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  sizeVariants  SizeVariant[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  rentalBookings RentalBooking[]
  blockedDates  BlockedDate[]
  reviews       Review[]
}

// ─────────────────────────────────────────────
// Product Image
// ─────────────────────────────────────────────

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  publicId  String? // Cloudinary public ID for deletion
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Size Variant
// ─────────────────────────────────────────────

model SizeVariant {
  id        String @id @default(cuid())
  productId String
  size      String // e.g. XS, S, M, L, XL, XXL, Free Size
  stock     Int    @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  rentalBookings RentalBooking[]

  @@unique([productId, size])
}

// ─────────────────────────────────────────────
// Cart
// ─────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id            String       @id @default(cuid())
  cartId        String
  productId     String
  sizeVariantId String?
  type          CartItemType
  quantity      Int          @default(1)
  rentalStart   DateTime?
  rentalEnd     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cart        Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  sizeVariant SizeVariant? @relation(fields: [sizeVariantId], references: [id])
}

// ─────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  userId        String
  orderType     OrderType
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  totalAmount   Float
  depositAmount Float         @default(0)
  depositStatus DepositStatus @default(HELD)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  items          OrderItem[]
  rentalBookings RentalBooking[]
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  productId     String
  sizeVariantId String?
  type          CartItemType
  quantity      Int
  priceAtOrder  Float        // snapshot of price at time of order
  rentalStart   DateTime?
  rentalEnd     DateTime?
  rentalDays    Int?

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  sizeVariant SizeVariant? @relation(fields: [sizeVariantId], references: [id])
}

// ─────────────────────────────────────────────
// Rental Booking
// ─────────────────────────────────────────────

model RentalBooking {
  id            String       @id @default(cuid())
  productId     String
  sizeVariantId String?
  orderId       String
  startDate     DateTime
  endDate       DateTime
  returnStatus  ReturnStatus @default(PENDING)
  damageNotes   String?
  createdAt     DateTime     @default(now())

  product     Product      @relation(fields: [productId], references: [id])
  sizeVariant SizeVariant? @relation(fields: [sizeVariantId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])
}

// ─────────────────────────────────────────────
// Blocked Dates (Admin)
// ─────────────────────────────────────────────

model BlockedDate {
  id        String   @id @default(cuid())
  productId String
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
}

// ─────────────────────────────────────────────
// Review
// ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId]) // one review per user per product
}
